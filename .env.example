PORT=3001

# Local dev
# FRONTEND_URL=http://localhost:5173

# Vercel production — set to your frontend Vercel URL (no trailing slash)
# FRONTEND_URL=https://your-legacy-app.vercel.app

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SECRET_KEY=your_secret_key

DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# OpenAI — Whisper STT + Realtime interviewer
OPENAI_API_KEY=your_openai_api_key
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE=nova
OPENAI_TTS_SPEED=0.94
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# AI interviewer voice
INTERVIEWER_TTS_PROVIDER=elevenlabs
INTERVIEWER_VOICE_ID=21m00Tcm4TlvDq8ikWAM
INTERVIEWER_TTS_MODEL=eleven_turbo_v2_5

ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MODEL=claude-opus-4-8

# ElevenLabs — voice cloning + natural TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5
ELEVENLABS_STABILITY=0.4
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_STYLE=0.15
ELEVENLABS_SPEAKER_BOOST=true

# HeyGen — voice cloning + talking video
HEYGEN_API_KEY=your_heygen_api_key
HEYGEN_RESOLUTION=720p
HEYGEN_ASPECT_RATIO=auto
HEYGEN_VOICE_SPEED=0.95
HEYGEN_VOICE_PITCH=0
HEYGEN_VOICE_VOLUME=1
HEYGEN_VOICE_LOCALE=en-US
HEYGEN_ELEVENLABS_ENGINE=true
HEYGEN_ELEVENLABS_MODEL=eleven_v3
HEYGEN_ELEVENLABS_STABILITY=0.5
HEYGEN_ELEVENLABS_SIMILARITY_BOOST=0.75

# LiveAvatar — real-time live video calls
LIVEAVATAR_API_KEY=your_liveavatar_api_key
LIVEAVATAR_AVATAR_ID=your_custom_avatar_uuid
LIVEAVATAR_SANDBOX=true

# Anam.ai — live video call with user's face + voice
ANAM_API_KEY=your_anam_api_key
ANAM_LLM_ID=ANAM_GPT_4O_MINI_V1
ANAM_AVATAR_MODEL=cara-3
ANAM_VIDEO_QUALITY=high
